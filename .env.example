# ============ Blog Syndicator — configuração ============
# Copie para .env e preencha. NÃO comite o .env.

# --- Blog / gatilho ---
RSS_URL=https://devsaderiva.com.br/rss.xml
SITE_NAME=Devs à Deriva
POLL_INTERVAL_MINUTES=10

# --- Comportamento ---
# Redes ativas (Fase 1). Depois: linkedin,instagram,threads,facebook
ENABLED_NETWORKS=mastodon,bluesky,telegram
# true = manda pra você aprovar no Telegram antes de publicar
APPROVAL_REQUIRED=true

# --- IA (geração da copy) ---
# Crie a chave em https://console.anthropic.com  (é SEPARADO da assinatura do Claude Code)
ANTHROPIC_API_KEY=
# Modelo: sonnet = ótimo custo/qualidade; haiku = mais barato; opus = melhor
LLM_MODEL=claude-sonnet-4-6

# --- Telegram (aprovação + publicação no canal) ---
# Crie um bot com @BotFather -> token. Dê /start no bot pra ele poder te mandar DM.
TELEGRAM_BOT_TOKEN=
# Seu chat id pessoal (pegue com @userinfobot). É pra onde vão as aprovações.
TELEGRAM_ADMIN_CHAT_ID=
# Canal onde publicar (ex.: @devsaderiva). O bot precisa ser ADMIN do canal.
TELEGRAM_CHANNEL_ID=

# --- Mastodon ---
# Instância onde você tem conta (ex.: https://mastodon.social)
MASTODON_INSTANCE=
# Ajustes -> Desenvolvimento -> Nova aplicação -> token de acesso (escopo write:statuses)
MASTODON_TOKEN=

# --- Bluesky ---
# Seu handle (ex.: devsaderiva.bsky.social)
BLUESKY_IDENTIFIER=
# Configurações -> App Passwords -> criar (NÃO use sua senha principal)
BLUESKY_APP_PASSWORD=

# --- Armazenamento de estado ---
DATA_DIR=./data
